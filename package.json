{
  "name": "budget-buddy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "ci": "npm run db:generate && npm run db:validate && npm run lint && npm run typecheck && npm run build",
